      "item": [
        {
          "name": "SETUP-01 · Ambil CSRF Token dari Halaman Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('[SETUP-01] Sanctum CSRF Cookie — HTTP 204', function () {",
                  "    pm.response.to.have.status(204);",
                  "});",
                  "",
                  "const xsrfCookie = pm.cookies.get('XSRF-TOKEN');",
                  "",
                  "if (xsrfCookie) {",
                  "    const decoded = decodeURIComponent(xsrfCookie);",
                  "    pm.collectionVariables.set('csrf_token', decoded);",
                  "    console.log('✅ CSRF Token (XSRF-TOKEN cookie) tersimpan.');",
                  "} else {",
                  "    console.warn('⚠️ XSRF-TOKEN cookie tidak ditemukan. Pastikan cookie jar aktif dan Sanctum sudah dikonfigurasi.');",
                  "}",
                  "",
                  "pm.test('[SETUP-01] CSRF Token berhasil diambil dari cookie (atau akan diambil dari HTML)', function () {",
                  "    const t = pm.collectionVariables.get('csrf_token');",
                  "    if (!t) {",
                  "        console.warn('⚠️ csrf_token belum tersedia — POS-01 akan mencoba mengambil dari HTML');",
                  "        // Tidak fail — biarkan POS-01 sebagai fallback",
                  "        pm.expect(true).to.be.true;",
                  "    } else {",
                  "        pm.expect(t).to.not.be.empty;",
                  "    }",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
